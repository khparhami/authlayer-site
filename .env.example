# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: https://authlayer.dev/api/auth/callback
#                           http://localhost:4321/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session signing — generate with: openssl rand -base64 32
SESSION_SECRET=

# Cloudflare Web Analytics — https://dash.cloudflare.com/ → Web Analytics
# CF_API_TOKEN needs "Account Analytics: Read" permission
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_SITE_TAG=

# Public beacon token (same as CF_SITE_TAG, exposed to browser)
PUBLIC_CF_SITE_TAG=
