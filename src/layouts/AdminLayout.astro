---
interface Props {
  title?: string;
  email?: string;
}
const { title = 'Admin', email } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — AuthLayer Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      :root {
        --bg:         #080c18;
        --bg-card:    #0f1526;
        --bg-hover:   #161d35;
        --border:     #1e2a45;
        --accent:     #38bdf8;
        --accent-dim: #0ea5e9;
        --purple:     #818cf8;
        --text:       #e2e8f0;
        --text-muted: #64748b;
        --text-dim:   #94a3b8;
        --green:      #34d399;
        --red:        #f87171;
        --font-sans:  'Inter', system-ui, sans-serif;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .topbar {
        background: var(--bg-card);
        border-bottom: 1px solid var(--border);
        padding: 0 1.5rem;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .topbar-left {
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .brand {
        font-size: 1rem;
        font-weight: 700;
        color: var(--accent);
        letter-spacing: -0.02em;
        text-decoration: none;
      }
      .divider {
        width: 1px;
        height: 18px;
        background: var(--border);
      }
      .page-title {
        font-size: 0.875rem;
        color: var(--text-muted);
      }
      .topbar-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.8rem;
      }
      .email-badge {
        color: var(--text-muted);
      }
      .logout-btn {
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.3rem 0.75rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 0.8rem;
        transition: color 0.15s, border-color 0.15s;
      }
      .logout-btn:hover {
        color: var(--red);
        border-color: rgba(248, 113, 113, 0.4);
        text-decoration: none;
      }
      main {
        flex: 1;
        max-width: 1100px;
        width: 100%;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-left">
        <a href="/admin" class="brand">AuthLayer</a>
        <div class="divider"></div>
        <span class="page-title">{title}</span>
      </div>
      <div class="topbar-right">
        {email && <span class="email-badge">{email}</span>}
        <a href="/api/auth/logout" class="logout-btn">Sign out</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
