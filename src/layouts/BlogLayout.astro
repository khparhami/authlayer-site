---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags } = post.data;

const formattedPub = pubDate.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpd = updatedDate?.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${title} | AuthLayer`} description={description}>
  <article class="post-wrap">
    <div class="container">
      <header class="post-header">
        <div class="post-tags">
          {tags.map(t => <span class="tag">{t}</span>)}
        </div>
        <h1>{title}</h1>
        <p class="post-meta">
          <span>By {author}</span>
          <span class="sep">·</span>
          <time datetime={pubDate.toISOString()}>{formattedPub}</time>
          {updatedDate && (
            <>
              <span class="sep">·</span>
              <span>Updated {formattedUpd}</span>
            </>
          )}
        </p>
        <p class="post-description">{description}</p>
      </header>

      <div class="post-body prose">
        <slot />
      </div>

      <footer class="post-footer">
        <a href="/blog" class="back-link">← Back to all articles</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post-wrap { padding: 3rem 0 5rem; }

  .post-header { margin-bottom: 3rem; max-width: 760px; }

  .post-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: #fff;
    margin-bottom: 1rem;
  }

  .post-meta {
    color: var(--text-muted);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .sep { color: var(--border); }

  .post-description {
    font-size: 1.1rem;
    color: var(--text-dim);
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
  }

  .prose { max-width: 760px; }

  .prose :global(h2) {
    font-size: 1.5rem;
    color: #fff;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .prose :global(h3) {
    font-size: 1.2rem;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) { margin-bottom: 1.25rem; color: var(--text-dim); }

  .prose :global(ul), .prose :global(ol) {
    margin: 1rem 0 1.5rem 1.5rem;
    color: var(--text-dim);
  }

  .prose :global(li) { margin-bottom: 0.4rem; }

  .prose :global(strong) { color: var(--text); font-weight: 600; }

  .prose :global(blockquote) {
    border-left: 3px solid var(--purple);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: rgba(129, 140, 248, 0.06);
    border-radius: 0 6px 6px 0;
    color: var(--text-dim);
  }

  .prose :global(a) { color: var(--accent); text-underline-offset: 3px; }

  .post-footer { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); }

  .back-link {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--accent); text-decoration: none; }
</style>
