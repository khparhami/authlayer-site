---
import BaseLayout from './BaseLayout.astro';
import AdUnit from '@/components/AdUnit.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, image } = post.data;

const ogImage = new URL(`/og/${post.slug}.png`, Astro.site).href;
const linkedInShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`;

const formattedPub = pubDate.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpd = updatedDate?.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${title} | AuthLayer`} description={description} image={ogImage}>
  <article class="post-wrap">
    <div class="container">
      <header class="post-header">
        <div class="post-tags">
          {tags.map(t => <span class="tag">{t}</span>)}
        </div>
        <h1>{title}</h1>
        <p class="post-meta">
          <span>By {author}</span>
          <span class="sep">·</span>
          <time datetime={pubDate.toISOString()}>{formattedPub}</time>
          {updatedDate && (
            <>
              <span class="sep">·</span>
              <span>Updated {formattedUpd}</span>
            </>
          )}
        </p>
        <p class="post-description">{description}</p>
      </header>

      {image && (
        <div class="hero-image">
          <img src={image} alt={title} />
        </div>
      )}

      <AdUnit slot="2910852937" format="horizontal" />

      <div class="post-body prose">
        <slot />
      </div>

      <AdUnit slot="2910852937" format="auto" />

      <footer class="post-footer">
        <a href="/blog" class="back-link">← Back to all articles</a>
        <a href={linkedInShareUrl} target="_blank" rel="noopener noreferrer" class="linkedin-share">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Share on LinkedIn
        </a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post-wrap { padding: 3rem 0 5rem; }

  .post-header { margin-bottom: 3rem; max-width: 760px; }

  .post-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: #fff;
    margin-bottom: 1rem;
  }

  .post-meta {
    color: var(--text-muted);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .sep { color: var(--border); }

  .post-description {
    font-size: 1.1rem;
    color: var(--text-dim);
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
  }

  .hero-image {
    margin-bottom: 2.5rem;
    border-radius: 12px;
    overflow: hidden;
    max-width: 760px;
    aspect-ratio: 16 / 9;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .prose { max-width: 760px; }

  .prose :global(h2) {
    font-size: 1.5rem;
    color: #fff;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .prose :global(h3) {
    font-size: 1.2rem;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) { margin-bottom: 1.25rem; color: var(--text-dim); }

  .prose :global(ul), .prose :global(ol) {
    margin: 1rem 0 1.5rem 1.5rem;
    color: var(--text-dim);
  }

  .prose :global(li) { margin-bottom: 0.4rem; }

  .prose :global(strong) { color: var(--text); font-weight: 600; }

  .prose :global(blockquote) {
    border-left: 3px solid var(--purple);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: rgba(129, 140, 248, 0.06);
    border-radius: 0 6px 6px 0;
    color: var(--text-dim);
  }

  .prose :global(a) { color: var(--accent); text-underline-offset: 3px; }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .back-link {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--accent); text-decoration: none; }

  .linkedin-share {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: #fff;
    background: #0a66c2;
    padding: 0.4rem 0.9rem;
    border-radius: 6px;
    transition: background 0.2s;
    text-decoration: none;
  }

  .linkedin-share:hover { background: #004182; text-decoration: none; }
</style>
