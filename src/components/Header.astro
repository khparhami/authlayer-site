---
const navLinks = [
  { label: 'Blog', href: '/blog' },
  { label: 'Guides', href: '/blog?tag=guide' },
  { label: 'Tools', href: '/tools' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="AuthLayer Home">
      <span class="logo-icon">&#9632;</span>
      <span class="logo-text">Auth<span class="accent">Layer</span></span>
    </a>

    <nav aria-label="Primary navigation">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath.startsWith(link.href.split('?')[0]) && link.href !== '/' }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(8, 12, 24, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .logo-icon { color: var(--accent); font-size: 0.85rem; }
  .accent { color: var(--accent); }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 0.25rem;
  }

  .nav-link {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
  }

  .nav-link:hover, .nav-link.active {
    color: var(--text);
    background: var(--bg-hover);
    text-decoration: none;
  }

  .nav-link.active { color: var(--accent); }
</style>
