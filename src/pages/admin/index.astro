---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';

const email = Astro.locals.userEmail as string;
const env = Astro.locals.runtime?.env ?? import.meta.env;

const CF_API_TOKEN = env.CF_API_TOKEN;
const CF_ZONE_ID   = env.CF_ZONE_ID;

// — URL params ———————————————————————————————————————————
const sp = Astro.url.searchParams;
const daysParam = parseInt(sp.get('days') ?? '30', 10);
const days = [7, 14, 30, 90].includes(daysParam) ? daysParam : 30;
const rawPage = sp.get('page') ?? '';
const safePage = /^\/[a-zA-Z0-9\-._~/]*$/.test(rawPage) ? rawPage : '';

// — Types ————————————————————————————————————————————————
interface PageviewRow { date: string; views: number }
interface TopPage { path: string; views: number }
interface Stats {
  totalViews: number;
  totalVisitors: number;
  pageviewsByDay: PageviewRow[];
  topPages: TopPage[];
  pageDetail: { daily: PageviewRow[] } | null;
}

let stats: Stats | null = null;
let analyticsError: string | null = null;

// — Fetch ————————————————————————————————————————————————
if (CF_API_TOKEN && CF_ZONE_ID) {
  try {
    const today = new Date();
    const since = new Date(today);
    since.setDate(since.getDate() - (days - 1));
    const sinceStr = since.toISOString().split('T')[0];
    const untilStr = today.toISOString().split('T')[0];

    const gql = (query: string) =>
      fetch('https://api.cloudflare.com/client/v4/graphql', {
        method: 'POST',
        headers: { Authorization: `Bearer ${CF_API_TOKEN}`, 'Content-Type': 'application/json' },
        body: JSON.stringify({ query }),
      });

    const dailyQuery = `query {
      viewer {
        zones(filter: { zoneTag: "${CF_ZONE_ID}" }) {
          httpRequests1dGroups(
            filter: { date_geq: "${sinceStr}", date_leq: "${untilStr}" }
            limit: ${days + 2}
            orderBy: [date_ASC]
          ) {
            sum { pageViews }
            uniq { uniques }
            dimensions { date }
          }
        }
      }
    }`;

    const topQuery = `query {
      viewer {
        zones(filter: { zoneTag: "${CF_ZONE_ID}" }) {
          httpRequestsAdaptiveGroups(
            filter: { date_geq: "${sinceStr}", date_leq: "${untilStr}" }
            limit: 10
            orderBy: [count_DESC]
          ) {
            count
            dimensions { clientRequestPath }
          }
        }
      }
    }`;

    const pageQuery = safePage ? `query {
      viewer {
        zones(filter: { zoneTag: "${CF_ZONE_ID}" }) {
          httpRequestsAdaptiveGroups(
            filter: { date_geq: "${sinceStr}", date_leq: "${untilStr}", requestSource: "eyeball", clientRequestPath: "${safePage}" }
            limit: ${days + 2}
            orderBy: [date_ASC]
          ) {
            count
            dimensions { date }
          }
        }
      }
    }` : null;

    const fetches: Promise<Response>[] = [gql(dailyQuery), gql(topQuery)];
    if (pageQuery) fetches.push(gql(pageQuery));

    const responses = await Promise.all(fetches);
    const jsons = await Promise.all(responses.map(r => r.json()));

    type DailyJson = {
      data?: { viewer: { zones: Array<{ httpRequests1dGroups: Array<{ sum: { pageViews: number }; uniq: { uniques: number }; dimensions: { date: string } }> }> } };
      errors?: Array<{ message: string }>;
    };
    type TopJson = {
      data?: { viewer: { zones: Array<{ httpRequestsAdaptiveGroups: Array<{ count: number; dimensions: { clientRequestPath: string } }> }> } };
      errors?: Array<{ message: string }>;
    };
    type PageJson = {
      data?: { viewer: { zones: Array<{ httpRequestsAdaptiveGroups: Array<{ count: number; dimensions: { date: string } }> }> } };
      errors?: Array<{ message: string }>;
    };

    const dailyJson = jsons[0] as DailyJson;
    const topJson   = jsons[1] as TopJson;
    const pageJson  = (jsons[2] ?? null) as PageJson | null;

    if (dailyJson.errors?.length) throw new Error(dailyJson.errors[0].message);
    if (topJson.errors?.length) throw new Error(`Top pages: ${topJson.errors[0].message}`);

    const dailyRows = dailyJson.data?.viewer?.zones?.[0]?.httpRequests1dGroups ?? [];
    const topRows   = topJson.data?.viewer?.zones?.[0]?.httpRequestsAdaptiveGroups ?? [];

    let totalViews = 0;
    let totalVisitors = 0;

    const pageviewsByDay: PageviewRow[] = dailyRows.map(r => {
      totalViews    += r.sum.pageViews;
      totalVisitors += r.uniq.uniques;
      return { date: r.dimensions.date, views: r.sum.pageViews };
    });

    const topPages: TopPage[] = topRows.map(r => ({
      path: r.dimensions.clientRequestPath || '/',
      views: r.count,
    }));

    let pageDetail: Stats['pageDetail'] = null;
    if (pageJson) {
      const rows = pageJson.data?.viewer?.zones?.[0]?.httpRequestsAdaptiveGroups ?? [];
      pageDetail = { daily: rows.map(r => ({ date: r.dimensions.date, views: r.count })) };
    }

    stats = { totalViews, totalVisitors, pageviewsByDay, topPages, pageDetail };
  } catch (err) {
    analyticsError = err instanceof Error ? err.message : 'Failed to load analytics';
  }
} else {
  analyticsError = 'Analytics not configured — set CF_API_TOKEN and CF_ZONE_ID.';
}

function fmt(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1)}K`;
  return n.toString();
}

const maxDay     = stats ? Math.max(...stats.pageviewsByDay.map(r => r.views), 1) : 1;
const maxPageDay = stats?.pageDetail ? Math.max(...stats.pageDetail.daily.map(r => r.views), 1) : 1;

function periodUrl(d: number): string {
  const u = new URL(Astro.url);
  u.searchParams.set('days', d.toString());
  return u.pathname + u.search;
}

function pageUrl(p: string): string {
  const u = new URL(Astro.url);
  u.searchParams.set('page', p);
  return u.pathname + u.search;
}

function clearPageUrl(): string {
  const u = new URL(Astro.url);
  u.searchParams.delete('page');
  return u.pathname + u.search;
}
---

<AdminLayout title="Analytics" email={email}>
  <div class="dash">
    <div class="dash-header">
      <h1 class="dash-title">Analytics</h1>
      <div class="period-select">
        {[7, 14, 30, 90].map(d => (
          <a href={periodUrl(d)} class={`period-btn${days === d ? ' active' : ''}`}>{d}d</a>
        ))}
      </div>
    </div>

    {analyticsError && (
      <div class="notice">
        <strong>Setup required:</strong> {analyticsError}
      </div>
    )}

    {stats && (
      <>
        <div class="stat-grid">
          <div class="stat-card">
            <span class="stat-label">Page Views</span>
            <span class="stat-value">{fmt(stats.totalViews)}</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">Unique Visitors</span>
            <span class="stat-value">{fmt(stats.totalVisitors)}</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">Avg Views / Day</span>
            <span class="stat-value">
              {stats.pageviewsByDay.length
                ? fmt(Math.round(stats.totalViews / stats.pageviewsByDay.length))
                : '—'}
            </span>
          </div>
        </div>

        {stats.pageviewsByDay.length > 0 && (
          <div class="section">
            <h2 class="section-title">Daily Pageviews</h2>
            <div class="chart">
              {stats.pageviewsByDay.map(row => (
                <div class="bar-wrap" title={`${row.date}: ${row.views} views`}>
                  <div class="bar" style={`height: ${Math.max(4, Math.round((row.views / maxDay) * 100))}%`}></div>
                  <span class="bar-label">{row.date.slice(5)}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {stats.topPages.length > 0 && (
          <div class="section">
            <h2 class="section-title">Top Pages <span class="section-hint">click a row to drill down</span></h2>
            <table class="pages-table">
              <thead>
                <tr>
                  <th>Path</th>
                  <th class="num-col">Views</th>
                </tr>
              </thead>
              <tbody>
                {stats.topPages.map(page => (
                  <tr class={safePage === page.path ? 'selected-row' : ''} data-href={pageUrl(page.path)}>
                    <td>
                      <span class="page-path">{page.path}</span>
                      <a href={page.path} target="_blank" rel="noopener" class="page-ext-link" title="Open page">↗</a>
                    </td>
                    <td class="num-col">{page.views.toLocaleString()}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {safePage && stats.pageDetail && (
          <div class="section">
            <div class="section-header">
              <h2 class="section-title"><code class="page-code">{safePage}</code></h2>
              <a href={clearPageUrl()} class="clear-btn">✕ Clear</a>
            </div>
            {stats.pageDetail.daily.length > 0 ? (
              <div class="chart">
                {stats.pageDetail.daily.map(row => (
                  <div class="bar-wrap" title={`${row.date}: ${row.views} views`}>
                    <div class="bar bar--page" style={`height: ${Math.max(4, Math.round((row.views / maxPageDay) * 100))}%`}></div>
                    <span class="bar-label">{row.date.slice(5)}</span>
                  </div>
                ))}
              </div>
            ) : (
              <p class="no-data">No data for this page in the selected period.</p>
            )}
          </div>
        )}
      </>
    )}
  </div>
<script>
  document.querySelectorAll<HTMLTableRowElement>('tr[data-href]').forEach(row => {
    row.addEventListener('click', e => {
      if (!(e.target as Element).closest('a')) {
        location.href = row.dataset.href!;
      }
    });
  });
</script>
</AdminLayout>

<style>
  .dash { display: flex; flex-direction: column; gap: 2rem; }

  .dash-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .dash-title {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .period-select {
    display: flex;
    gap: 4px;
  }
  .period-btn {
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    border: 1px solid var(--border);
    background: transparent;
    transition: background 0.15s, color 0.15s;
  }
  .period-btn:hover { background: var(--bg-hover); color: var(--text); }
  .period-btn.active { background: var(--accent); color: #000; border-color: var(--accent); }

  .notice {
    background: rgba(56, 189, 248, 0.07);
    border: 1px solid rgba(56, 189, 248, 0.2);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    font-size: 0.875rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .section { display: flex; flex-direction: column; gap: 1rem; }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .section-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .section-hint {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--text-muted);
    text-transform: none;
    letter-spacing: 0;
  }

  /* Bar chart */
  .chart {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem 1rem 0.5rem;
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 160px;
    overflow-x: auto;
  }
  .bar-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    flex: 1;
    min-width: 16px;
    height: 100%;
  }
  .bar {
    width: 100%;
    background: var(--accent);
    border-radius: 3px 3px 0 0;
    opacity: 0.75;
    min-height: 4px;
    transition: opacity 0.15s;
  }
  .bar--page { background: #a78bfa; }
  .bar-wrap:hover .bar { opacity: 1; }
  .bar-label {
    font-size: 0.6rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* Top pages table */
  .pages-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    font-size: 0.875rem;
  }
  .pages-table th {
    background: var(--bg-hover);
    padding: 0.65rem 1rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .pages-table td {
    padding: 0.65rem 1rem;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
  }
  .pages-table tr:hover td { background: var(--bg-hover); }
  .selected-row td { background: rgba(167, 139, 250, 0.08); }
  .pages-table tbody tr[data-href] { cursor: pointer; }
  .page-path {
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
  }
  .page-ext-link {
    margin-left: 0.5rem;
    color: var(--text-muted);
    font-size: 0.75rem;
    text-decoration: none;
    opacity: 0.6;
  }
  .page-ext-link:hover { opacity: 1; color: var(--accent); }
  .num-col { text-align: right; font-variant-numeric: tabular-nums; }

  .page-code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 600;
    color: #a78bfa;
    text-transform: none;
    letter-spacing: 0;
  }
  .clear-btn {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 5px;
    white-space: nowrap;
  }
  .clear-btn:hover { color: var(--text); border-color: var(--text-muted); }

  .no-data {
    color: var(--text-muted);
    font-size: 0.875rem;
    padding: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
  }
</style>
