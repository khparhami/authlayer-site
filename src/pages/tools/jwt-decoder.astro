---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="JWT Decoder | AuthLayer"
  description="Decode and inspect JWT tokens instantly in your browser. Headers, payload claims, and timestamp formatting — nothing is sent to a server."
>
  <section class="jwt-page">
    <div class="container">
      <header class="page-header">
        <span class="tag">Tools</span>
        <h1>JWT Decoder</h1>
        <p class="subtitle">
          Paste a JSON Web Token to inspect its header and payload claims.
          All decoding happens in your browser — nothing is sent to a server.
        </p>
      </header>

      <div class="decoder-layout">
        <div class="pane pane-encoded">
          <div class="pane-title">Encoded</div>
          <textarea
            id="jwt-input"
            class="token-textarea"
            placeholder="Paste a JWT here…"
            spellcheck="false"
            autocorrect="off"
            autocapitalize="off"
          ></textarea>
          <div id="token-colored" class="token-colored" aria-hidden="true"></div>
          <p id="error-msg" class="error-msg" hidden>
            Not a valid JWT — expected three dot-separated base64url segments.
          </p>
        </div>

        <div class="pane pane-decoded">
          <div class="pane-title">Decoded</div>

          <div class="decoded-block">
            <div class="block-header">
              <span class="dot dot-h"></span>
              <span class="block-title">Header</span>
              <button class="copy-btn" data-target="header-json" hidden>Copy</button>
            </div>
            <pre id="header-json" class="json-output"><span class="placeholder">Waiting for input…</span></pre>
          </div>

          <div class="decoded-block">
            <div class="block-header">
              <span class="dot dot-p"></span>
              <span class="block-title">Payload</span>
              <button class="copy-btn" data-target="payload-json" hidden>Copy</button>
            </div>
            <pre id="payload-json" class="json-output"><span class="placeholder">Waiting for input…</span></pre>
          </div>

          <div class="decoded-block">
            <div class="block-header">
              <span class="dot dot-s"></span>
              <span class="block-title">Signature</span>
              <button class="copy-btn" data-target="sig-value" hidden>Copy</button>
            </div>
            <pre id="sig-value" class="json-output sig-wrap"><span class="placeholder">Waiting for input…</span></pre>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('jwt-input') as HTMLTextAreaElement;
  const tokenColored = document.getElementById('token-colored')!;
  const headerJson = document.getElementById('header-json')!;
  const payloadJson = document.getElementById('payload-json')!;
  const sigValue = document.getElementById('sig-value')!;
  const errorMsg = document.getElementById('error-msg')!;

  const TIME_CLAIMS = new Set(['exp', 'iat', 'nbf', 'auth_time', 'updated_at']);

  function b64urlDecode(str: string): string {
    str = str.replace(/-/g, '+').replace(/_/g, '/');
    while (str.length % 4) str += '=';
    return atob(str);
  }

  function esc(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function highlight(json: string): string {
    return esc(json).replace(
      /("(\\u[a-fA-F0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
      (match) => {
        let cls = 'n';
        if (/^"/.test(match)) cls = /:$/.test(match) ? 'k' : 's';
        else if (/true|false/.test(match)) cls = 'b';
        else if (/null/.test(match)) cls = 'nl';
        return `<span class="jh-${cls}">${match}</span>`;
      }
    );
  }

  function formatPayload(obj: Record<string, unknown>): string {
    let html = highlight(JSON.stringify(obj, null, 2));
    for (const claim of TIME_CLAIMS) {
      if (typeof obj[claim] === 'number') {
        const fmt = esc(new Date((obj[claim] as number) * 1000).toUTCString());
        html = html.replace(
          new RegExp(`(<span class="jh-k">"${claim}":<\\/span>\\s*<span class="jh-n">)(\\d+)(<\\/span>)`),
          `$1$2$3 <span class="jh-ts">// ${fmt}</span>`
        );
      }
    }
    return html;
  }

  function setCopyVisible(id: string, visible: boolean): void {
    const btn = document.querySelector<HTMLButtonElement>(`[data-target="${id}"]`);
    if (btn) btn.hidden = !visible;
  }

  function reset(): void {
    tokenColored.innerHTML = '';
    const placeholder = '<span class="placeholder">Waiting for input…</span>';
    headerJson.innerHTML = placeholder;
    payloadJson.innerHTML = placeholder;
    sigValue.innerHTML = placeholder;
    errorMsg.hidden = true;
    ['header-json', 'payload-json', 'sig-value'].forEach(id => setCopyVisible(id, false));
  }

  function showError(): void {
    tokenColored.innerHTML = '';
    const dash = '<span class="placeholder">–</span>';
    headerJson.innerHTML = dash;
    payloadJson.innerHTML = dash;
    sigValue.innerHTML = dash;
    errorMsg.hidden = false;
    ['header-json', 'payload-json', 'sig-value'].forEach(id => setCopyVisible(id, false));
  }

  function decode(token: string): void {
    token = token.trim();
    if (!token) { reset(); return; }

    const parts = token.split('.');
    errorMsg.hidden = true;
    if (parts.length !== 3) { showError(); return; }

    try {
      const headerObj = JSON.parse(b64urlDecode(parts[0]));
      const payloadObj = JSON.parse(b64urlDecode(parts[1]));

      tokenColored.innerHTML =
        `<span class="tc-h">${esc(parts[0])}</span>` +
        `<span class="tc-dot">.</span>` +
        `<span class="tc-p">${esc(parts[1])}</span>` +
        `<span class="tc-dot">.</span>` +
        `<span class="tc-s">${esc(parts[2])}</span>`;

      headerJson.innerHTML = highlight(JSON.stringify(headerObj, null, 2));
      payloadJson.innerHTML = formatPayload(payloadObj);
      sigValue.innerHTML = `<span class="tc-s">${esc(parts[2])}</span>`;

      ['header-json', 'payload-json', 'sig-value'].forEach(id => setCopyVisible(id, true));
    } catch {
      showError();
    }
  }

  input.addEventListener('input', () => decode(input.value));

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = document.getElementById(btn.dataset.target!)!;
      navigator.clipboard.writeText(target.textContent ?? '').then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
      });
    });
  });
</script>

<style>
  .jwt-page { padding: 3rem 0 5rem; }

  .page-header { margin-bottom: 2.5rem; }
  .page-header .tag { margin-bottom: 0.75rem; }
  .page-header h1 { font-size: 2rem; color: #fff; margin-top: 0.5rem; margin-bottom: 0.75rem; }
  .subtitle { color: var(--text-dim); max-width: 600px; font-size: 0.95rem; }

  .decoder-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .decoder-layout { grid-template-columns: 1fr; }
  }

  .pane-title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  /* Encoded side */
  .token-textarea {
    width: 100%;
    min-height: 210px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.65;
    padding: 1rem;
    resize: vertical;
    outline: none;
    transition: border-color 0.2s;
    word-break: break-all;
  }
  .token-textarea:focus { border-color: var(--accent); color: var(--text); }
  .token-textarea::placeholder { color: var(--text-muted); }

  .token-colored {
    display: none;
    margin-top: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.7;
    word-break: break-all;
  }
  .token-colored:not(:empty) { display: block; }

  .tc-h   { color: #fb7185; }
  .tc-p   { color: #c084fc; }
  .tc-s   { color: var(--accent); }
  .tc-dot { color: var(--text-muted); }

  .error-msg {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: #fb7185;
  }

  /* Decoded side */
  .decoded-block { margin-bottom: 1rem; }

  .block-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .dot-h { background: #fb7185; }
  .dot-p { background: #c084fc; }
  .dot-s { background: var(--accent); }

  .block-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-dim);
  }

  .copy-btn {
    margin-left: auto;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.2em 0.65em;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .copy-btn:hover { color: var(--accent); border-color: var(--accent); }

  /* Override global pre margin inside these blocks */
  .json-output {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }
  .sig-wrap { word-break: break-all; white-space: pre-wrap; }

  .placeholder { color: var(--text-muted); font-style: italic; }

  /* JSON syntax highlighting */
  .jh-k  { color: var(--accent); }
  .jh-s  { color: var(--green); }
  .jh-n  { color: #fdba74; }
  .jh-b  { color: #c084fc; }
  .jh-nl { color: var(--text-dim); }
  .jh-ts { color: var(--text-muted); font-style: italic; }
</style>
