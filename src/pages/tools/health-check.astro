---
import BaseLayout from '@/layouts/BaseLayout.astro';

const PAID_CHECK_PREVIEWS = [
  { name: 'SameSite Cookie Policy', category: 'cookies' },
  { name: 'Secure Cookie Prefixes', category: 'cookies' },
  { name: 'Content-Security-Policy Strength', category: 'headers' },
  { name: 'Referrer-Policy', category: 'headers' },
  { name: 'Permissions-Policy', category: 'headers' },
  { name: 'Cross-Origin Isolation (COOP/CORP)', category: 'headers' },
  { name: 'OIDC Discovery Endpoint', category: 'oauth' },
  { name: 'PKCE Enforcement', category: 'oauth' },
  { name: 'Deprecated OAuth Grant Types', category: 'oauth' },
  { name: 'Phishing-Resistant Authentication', category: 'oauth' },
  { name: 'Auth Endpoint Protection', category: 'exposure' },
  { name: 'DKIM Record', category: 'email' },
  { name: 'DMARC Policy Level', category: 'email' },
  { name: 'SPF Enforcement Level', category: 'email' },
  { name: 'Auth Subdomain Surface', category: 'exposure' },
  { name: 'CORS Policy', category: 'headers' },
  { name: 'Security.txt', category: 'exposure' },
];
---

<BaseLayout
  title="Identity Security Health Check | AuthLayer"
  description="Scan any domain for authentication and identity security issues — HTTPS, HSTS, cookie flags, SPF, DMARC, OAuth endpoints, passkeys, and more. Free and full report options."
>
  <section class="hc-page">
    <div class="container">

      <header class="page-header">
        <span class="tag">Tools</span>
        <h1>Identity Security Health Check</h1>
        <p class="subtitle">
          Passive scan of any domain's authentication and identity security posture.
          All checks run server-side — HTTP headers, DNS records, and well-known endpoints.
          Nothing is written to the target.
        </p>
      </header>

      <div class="input-card">
        <div class="input-row">
          <div class="domain-field">
            <label for="domain-input" class="sr-only">Domain or login URL to scan</label>
            <input
              id="domain-input"
              type="text"
              class="domain-input"
              placeholder="example.com or https://login.example.com/signin"
              autocomplete="off"
              spellcheck="false"
              autocorrect="off"
              autocapitalize="off"
            />
          </div>
          <div class="btn-group">
            <button id="btn-free" class="btn btn-primary" type="button">Run Free Report</button>
            <button id="btn-paid" class="btn btn-pro" type="button">
              Full Report
              <span class="pro-badge">Pro</span>
            </button>
          </div>
        </div>
        <p id="input-error" class="input-error" hidden>Enter a domain (e.g. example.com) or a full login URL (e.g. https://login.example.com/signin)</p>
      </div>

      <div id="results-area" class="results-area">

        <div id="state-empty" class="state-empty">
          <div class="empty-icon">⬡</div>
          <p>Enter a domain or login URL above to scan its identity security posture.</p>
        </div>

        <div id="state-loading" class="state-loading" hidden>
          <div class="spinner"></div>
          <div class="loading-text">
            Running checks on <strong id="loading-domain"></strong>…
          </div>
          <p class="loading-sub">Checks run in parallel — results appear momentarily.</p>
        </div>

        <div id="state-results" hidden>

          <div class="score-row">
            <div id="score-ring" class="score-ring" data-grade="?">
              <div class="score-grade" id="score-grade">?</div>
              <div class="score-num" id="score-num">—</div>
            </div>
            <div class="score-meta">
              <div class="score-domain" id="score-domain"></div>
              <div class="summary-chips" id="summary-chips"></div>
              <div class="report-badge" id="report-badge"></div>
            </div>
          </div>

          <div id="results-list" class="results-list"></div>

          <div id="paid-teaser" class="paid-teaser" hidden>
            <div class="teaser-header">
              <span class="lock-icon">⊘</span>
              <div>
                <div class="teaser-title">Full Report — 16 additional checks</div>
                <div class="teaser-sub">Cookie policy, CSP strength, OAuth posture, DKIM, DMARC enforcement, subdomain surface, and more</div>
              </div>
            </div>
            <ul class="teaser-list" id="teaser-list"></ul>
            <button id="btn-upgrade" class="btn btn-pro teaser-btn" type="button">
              Run Full Report
              <span class="pro-badge">Pro</span>
            </button>
          </div>

        </div>

        <div id="state-error" class="state-error" hidden>
          <span class="error-icon">✗</span>
          <span id="error-text"></span>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ PAID_CHECK_PREVIEWS }}>
  const domainInput = document.getElementById('domain-input');
  const btnFree     = document.getElementById('btn-free');
  const btnPaid     = document.getElementById('btn-paid');
  const btnUpgrade  = document.getElementById('btn-upgrade');
  const inputError  = document.getElementById('input-error');

  const stateEmpty   = document.getElementById('state-empty');
  const stateLoading = document.getElementById('state-loading');
  const stateResults = document.getElementById('state-results');
  const stateError   = document.getElementById('state-error');

  const loadingDomain = document.getElementById('loading-domain');
  const scoreRing     = document.getElementById('score-ring');
  const scoreGrade    = document.getElementById('score-grade');
  const scoreNum      = document.getElementById('score-num');
  const scoreDomain   = document.getElementById('score-domain');
  const summaryChips  = document.getElementById('summary-chips');
  const reportBadge   = document.getElementById('report-badge');
  const resultsList   = document.getElementById('results-list');
  const paidTeaser    = document.getElementById('paid-teaser');
  const teaserList    = document.getElementById('teaser-list');
  const errorText     = document.getElementById('error-text');

  const CATEGORY_LABELS = {
    transport: 'Transport Security',
    cookies:   'Cookie Security',
    headers:   'HTTP Security Headers',
    email:     'Email Authentication',
    oauth:     'OAuth / OIDC Posture',
    exposure:  'Exposure & Disclosure',
  };

  const STATUS_ICON  = { pass: '✓', fail: '✗', warn: '⚠', info: '●', error: '?' };
  const STATUS_LABEL = { pass: 'Pass', fail: 'Fail', warn: 'Warning', info: 'Info', error: 'N/A' };

  const SEV_ICON  = { critical: '◆', high: '▲', medium: '■', low: '▸', info: '·' };
  const SEV_LABEL = { critical: 'Critical', high: 'High', medium: 'Medium', low: 'Low', info: 'Info' };

  const SEVERITY_ORDER = { critical: 0, high: 1, medium: 2, low: 3, info: 4 };

  function sanitizeDomainClient(input) {
    let d = input.trim().toLowerCase();
    d = d.replace(/^https?:\/\//, '').replace(/\/.*$/, '');
    return d || null;
  }

  function isValidDomain(d) {
    if (!d) return false;
    return /^[a-z0-9]([a-z0-9\-.]{0,251}[a-z0-9])?$/.test(d) &&
      !/^(localhost|127\.|10\.|192\.168\.|169\.254\.|0\.)/.test(d);
  }

  function setState(name) {
    stateEmpty.hidden   = name !== 'empty';
    stateLoading.hidden = name !== 'loading';
    stateResults.hidden = name !== 'results';
    stateError.hidden   = name !== 'error';
  }

  function gradeColor(grade) {
    return { A: '#34d399', B: '#4ade80', C: '#fbbf24', D: '#f97316', F: '#f87171' }[grade] ?? '#64748b';
  }

  function severityClass(sev) {
    return { critical: 'sev-critical', high: 'sev-high', medium: 'sev-medium', low: 'sev-low', info: 'sev-info' }[sev] ?? '';
  }

  function buildResults(data) {
    const { domain, report, score, grade, checks } = data;

    // Score ring
    const color = gradeColor(grade);
    scoreRing.style.setProperty('--grade-color', color);
    scoreGrade.textContent = grade;
    scoreNum.textContent = `${score}/100`;
    scoreDomain.textContent = domain;

    // Report badge
    reportBadge.textContent = report === 'paid' ? 'Full Report' : 'Free Report';
    reportBadge.className = 'report-badge ' + (report === 'paid' ? 'badge-paid' : 'badge-free');

    // Summary chips
    const passed  = checks.filter(c => c.status === 'pass').length;
    const warned  = checks.filter(c => c.status === 'warn').length;
    const failed  = checks.filter(c => c.status === 'fail').length;
    const errored = checks.filter(c => c.status === 'error').length;
    summaryChips.innerHTML = [
      `<span class="chip chip-pass">${passed} passed</span>`,
      warned  ? `<span class="chip chip-warn">${warned} warning${warned > 1 ? 's' : ''}</span>` : '',
      failed  ? `<span class="chip chip-fail">${failed} failed</span>` : '',
      errored ? `<span class="chip chip-err">${errored} error${errored > 1 ? 's' : ''}</span>` : '',
    ].filter(Boolean).join('');

    // Group by risk level
    const RISK_GROUPS = [
      { key: 'critical', label: 'Critical Issues',    icon: '◆', color: '#ef4444' },
      { key: 'high',     label: 'High Risk',          icon: '▲', color: '#f97316' },
      { key: 'medium',   label: 'Medium Risk',        icon: '■', color: '#eab308' },
      { key: 'low',      label: 'Low Risk',           icon: '◉', color: '#3b82f6' },
      { key: 'pass',     label: 'Passing Checks',     icon: '✓', color: '#22c55e' },
      { key: 'na',       label: 'Info / Not Checked', icon: '○', color: '#64748b' },
    ];

    function getGroup(c) {
      if (c.status === 'pass') return 'pass';
      if (c.status === 'info' || c.status === 'error') return 'na';
      const s = c.severity;
      return (s === 'critical' || s === 'high' || s === 'medium') ? s : 'low';
    }

    const grouped = {};
    for (const g of RISK_GROUPS) grouped[g.key] = [];
    for (const c of checks) grouped[getGroup(c)].push(c);

    function buildCard(check) {
      const isError  = check.status === 'error';
      const isPass   = check.status === 'pass';
      const showSev  = check.status === 'fail' || check.status === 'warn';
      const hasDetail = check.detail || check.remediation || isError;

      // Inline refs shown below the finding for fail/warn — justify why it's an issue
      const inlineRefsHtml = (showSev && check.references?.length) ? `
        <div class="inline-refs">${
          check.references.slice(0, 3).map(r =>
            `<a href="${escHtml(r.url)}" target="_blank" rel="noopener noreferrer" class="inline-ref">${escHtml(r.label)}</a>`
          ).join('')
        }</div>` : '';

      // Full refs in the expanded panel
      const allRefsHtml = check.references?.length ? `
        <div class="ref-row">
          <span class="ref-label">Standards &amp; References</span>
          <div class="ref-links">${
            check.references.map(r =>
              `<a href="${escHtml(r.url)}" target="_blank" rel="noopener noreferrer" class="ref-link">${escHtml(r.label)}</a>`
            ).join('')
          }</div>
        </div>` : '';

      const errorBannerHtml = isError ? `
        <div class="error-banner">
          <span class="error-banner-icon">?</span>
          <div>
            <div class="error-banner-title">Could not complete this check</div>
            <div class="error-banner-body">${escHtml(check.errorReason ?? 'The domain may be unreachable, the request timed out, or the endpoint does not exist. This is not a security finding.')}</div>
          </div>
        </div>` : '';

      const detailHtml = hasDetail ? `
        <div class="result-detail" hidden>
          ${isError ? errorBannerHtml : ''}
          ${check.detail ? `<p class="detail-text">${escHtml(check.detail)}</p>` : ''}
          ${check.remediation ? `<div class="remediation"><span class="remed-label">How to fix</span>${escHtml(check.remediation)}</div>` : ''}
          ${allRefsHtml}
        </div>` : '';

      const card = document.createElement('div');
      card.className = `result-card status-${check.status}`;
      card.innerHTML = `
        <div class="result-row${hasDetail ? ' expandable' : ''}"${hasDetail ? ' role="button" tabindex="0"' : ''}>
          <span class="status-dot status-${check.status}">${STATUS_ICON[check.status] ?? '?'}</span>
          <div class="result-body">
            <div class="result-header-row">
              <span class="check-name">${escHtml(check.name)}</span>
              ${showSev ? `<span class="sev-badge sev-${check.severity}"><span class="sev-icon">${SEV_ICON[check.severity] ?? ''}</span>${SEV_LABEL[check.severity] ?? check.severity}</span>` : ''}
              ${isError ? '<span class="sev-badge sev-na">N/A</span>' : ''}
            </div>
            <span class="check-finding">${escHtml(check.finding)}</span>
            ${inlineRefsHtml}
          </div>
          ${hasDetail ? '<span class="expand-arrow" aria-hidden="true">▸</span>' : ''}
        </div>
        ${detailHtml}`;

      if (hasDetail) {
        const row  = card.querySelector('.result-row');
        const detail = card.querySelector('.result-detail');
        const arrow  = card.querySelector('.expand-arrow');
        const toggle = () => {
          const open = !detail.hidden;
          detail.hidden = open;
          if (arrow) arrow.textContent = open ? '▸' : '▾';
          card.classList.toggle('expanded', !open);
        };
        row.addEventListener('click', toggle);
        row.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); } });
      }
      return card;
    }

    resultsList.innerHTML = '';
    for (const group of RISK_GROUPS) {
      const items = grouped[group.key];
      if (!items.length) continue;

      const section = document.createElement('div');
      section.className = `risk-section risk-section-${group.key}`;

      const header = document.createElement('div');
      header.className = `risk-header risk-${group.key}`;
      header.innerHTML = `
        <span class="risk-hicon">${group.icon}</span>
        <span class="risk-hlabel">${group.label}</span>
        <span class="risk-hcount">${items.length}</span>`;
      section.appendChild(header);

      const cardsDiv = document.createElement('div');
      cardsDiv.className = `risk-cards risk-cards-${group.key}`;
      for (const check of items) cardsDiv.appendChild(buildCard(check));
      section.appendChild(cardsDiv);

      resultsList.appendChild(section);
    }

    // Paid teaser (only for free reports)
    if (report === 'free') {
      teaserList.innerHTML = PAID_CHECK_PREVIEWS.map(c =>
        `<li class="teaser-item">
          <span class="lock-pill">🔒</span>
          <span class="teaser-check-name">${escHtml(c.name)}</span>
          <span class="teaser-cat">${CATEGORY_LABELS[c.category] ?? c.category}</span>
        </li>`
      ).join('');
      paidTeaser.hidden = false;
    } else {
      paidTeaser.hidden = true;
    }
  }

  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function parseInput(raw) {
    const trimmed = raw.trim();
    if (/^https?:\/\//i.test(trimmed)) {
      try {
        const u = new URL(trimmed.startsWith('http://') ? trimmed.replace(/^http:\/\//i, 'https://') : trimmed);
        return { domain: u.hostname.toLowerCase(), authUrl: u.href };
      } catch {
        return { domain: null, authUrl: null };
      }
    }
    const domain = sanitizeDomainClient(trimmed);
    return { domain, authUrl: null };
  }

  async function runReport(reportType) {
    const { domain, authUrl } = parseInput(domainInput.value);

    inputError.hidden = true;
    if (!isValidDomain(domain)) {
      inputError.hidden = false;
      domainInput.focus();
      return;
    }

    setState('loading');
    loadingDomain.textContent = authUrl ?? domain;
    btnFree.disabled = true;
    btnPaid.disabled = true;

    try {
      let apiUrl = `/api/health-check?domain=${encodeURIComponent(domain)}&report=${reportType}`;
      if (authUrl) apiUrl += `&authUrl=${encodeURIComponent(authUrl)}`;
      const res = await fetch(apiUrl);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? 'Scan failed');
      buildResults(data);
      setState('results');
    } catch (e) {
      errorText.textContent = e.message ?? 'An unexpected error occurred';
      setState('error');
    } finally {
      btnFree.disabled = false;
      btnPaid.disabled = false;
    }
  }

  btnFree.addEventListener('click', () => runReport('free'));
  btnPaid.addEventListener('click', () => runReport('paid'));
  btnUpgrade?.addEventListener('click', () => runReport('paid'));

  domainInput.addEventListener('keydown', e => {
    if (e.key === 'Enter') runReport('free');
  });
</script>

<style>
  /* ─── Page ───────────────────────────────────────── */
  .hc-page { padding: 3rem 0 6rem; }

  .page-header { margin-bottom: 2rem; }
  .page-header .tag { margin-bottom: 0.75rem; }
  .page-header h1 { font-size: 2rem; color: #fff; margin-top: 0.5rem; margin-bottom: 0.75rem; }
  .subtitle { color: var(--text-dim); max-width: 640px; font-size: 0.95rem; line-height: 1.6; }

  /* ─── Input card ─────────────────────────────────── */
  .input-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .input-row {
    display: flex;
    gap: 0.75rem;
    align-items: stretch;
    flex-wrap: wrap;
  }

  .domain-field { flex: 1; min-width: 220px; }

  .domain-input {
    width: 100%;
    height: 100%;
    min-height: 46px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.65rem 1.1rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }
  .domain-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.12);
  }
  .domain-input::placeholder { color: var(--text-muted); }

  .btn-group { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }

  .btn {
    padding: 0.65rem 1.4rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s, background 0.15s, box-shadow 0.15s;
    white-space: nowrap;
  }
  .btn:disabled { opacity: 0.45; cursor: not-allowed; }

  .btn-primary { background: var(--accent); color: #080c18; }
  .btn-primary:hover:not(:disabled) { opacity: 0.88; box-shadow: 0 0 0 3px rgba(52,211,153,0.20); }

  .btn-pro {
    background: transparent;
    border: 1px solid #818cf8;
    color: #818cf8;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-pro:hover:not(:disabled) { background: rgba(129,140,248,0.10); }

  .pro-badge {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    background: rgba(129,140,248,0.15);
    border: 1px solid rgba(129,140,248,0.30);
    color: #818cf8;
    padding: 0.15em 0.5em;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .input-error { color: #f87171; font-size: 0.82rem; margin-top: 0.5rem; }

  /* ─── States ─────────────────────────────────────── */
  .results-area { min-height: 200px; }

  .state-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 5rem 1rem;
    color: var(--text-muted);
    text-align: center;
  }
  .empty-icon { font-size: 2.5rem; opacity: 0.25; line-height: 1; }

  .state-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 5rem 1rem;
    color: var(--text-dim);
    text-align: center;
  }
  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.75s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading-text { font-size: 1rem; color: var(--text); font-weight: 500; }
  .loading-sub  { font-size: 0.82rem; color: var(--text-muted); }

  .state-error {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1rem 1.25rem;
    background: rgba(248,113,113,0.08);
    border: 1px solid rgba(248,113,113,0.30);
    border-radius: 10px;
    color: #f87171;
    font-size: 0.875rem;
  }
  .error-icon { font-size: 1.1rem; flex-shrink: 0; }

  /* ─── Score card ─────────────────────────────────── */
  .score-row {
    display: flex;
    align-items: center;
    gap: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    position: relative;
    overflow: hidden;
  }
  .score-row::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 80% at 10% 50%, rgba(52,211,153,0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .score-ring {
    --grade-color: #64748b;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 5px solid var(--grade-color);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--grade-color) 12%, transparent);
    box-shadow: 0 0 24px color-mix(in srgb, var(--grade-color) 20%, transparent);
    position: relative;
    z-index: 1;
  }
  .score-grade {
    font-size: 2.75rem;
    font-weight: 900;
    color: var(--grade-color);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .score-num {
    font-size: 0.6rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }

  .score-meta {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    position: relative;
    z-index: 1;
  }
  .score-domain {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .summary-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.1rem; }
  .report-badge {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.25em 0.8em;
    border-radius: 5px;
    align-self: flex-start;
  }

  /* ─── Mobile (static template elements only) ─────── */
  @media (max-width: 768px) {
    .input-row    { flex-direction: column; }
    .domain-field { width: 100%; }
    .btn-group    { width: 100%; }
    .btn          { flex: 1; justify-content: center; }
    .score-row    { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
  }
</style>

<!-- Styles for elements created dynamically by JavaScript must be global
     because JS-created DOM nodes don't receive Astro's data-astro-cid attribute -->
<style is:global>

  /* ─── Summary chips (innerHTML) ─────────────────── */
  .chip { font-size: 0.73rem; font-weight: 700; padding: 0.3em 0.85em; border-radius: 9999px; letter-spacing: 0.03em; }
